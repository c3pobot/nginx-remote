server {
    listen 3100;
    access_log off;
    client_max_body_size 500m;
    client_body_buffer_size 2048M;
    location / {
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection $http_connection;
      proxy_set_header Host $http_host;
      proxy_pass http://ga-server:3000;
    }
}
